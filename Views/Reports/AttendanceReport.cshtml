@model IEnumerable<RoyalAcademy.Models.Attendance>

@{
    ViewData["Title"] = "Attendance Report";
}

<h2>Attendance Report</h2>

<table class="table">
    <thead>
        <tr>
            <th>Student Code</th>
            <th>Student Name</th>
            <th>Date</th>
            <th>Status</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Student.StudentCode</td>
                <td>@item.Student.FullName</td>
                <td>@item.Date.ToString("dd-MM-yyyy")</td>
                <td>@(item.IsPresent ? "Present" : "Absent")</td>
            </tr>
        }
    </tbody>
</table>

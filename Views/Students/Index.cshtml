@model IEnumerable<RoyalAcademy.Models.Student>

<h2>Students</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Add Student</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Code</th>
            <th>Full Name</th>
            <th>Email</th>
            <th>DOB</th>
            <th>Course</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var s in Model)
        {
            <tr>
                <td>@s.StudentCode</td>
                <td>@s.FullName</td>
                <td>@s.Email</td>
                <td>@s.DateOfBirth.ToString("yyyy-MM-dd")</td>
                <td>@s.Course?.CourseName</td>
                <td>
                    <a asp-action="Details" asp-route-id="@s.Id" class="btn btn-info btn-sm">Details</a>
                    <a asp-action="Edit" asp-route-id="@s.Id" class="btn btn-warning btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@s.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>